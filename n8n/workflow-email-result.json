    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "gpt-4.1",
          "mode": "list",
          "cachedResultName": "GPT-4.1"
        },
        "messages": {
          "values": [
            {
              "content": "Você é um assistente que extrai informações de emails de laboratórios veterinários.\nOs resultados podem estar no corpo do email OU no PDF anexado (ou em ambos).\nPriorize as informações do PDF quando disponível, pois geralmente é mais completo.\nSe o email não for de um laboratório veterinário, retorne todos os campos como null.\nRetorne APENAS um objeto JSON válido, sem markdown, sem explicações.",
              "role": "system"
            },
            {
              "content": "=Extraia os seguintes dados deste email de laboratório veterinário:\n- pet_name: nome do animal\n- client_name: nome do tutor/proprietário/responsável\n- exam_type: tipo de exame (ex: Hemograma, Bioquímico, Urinálise, Ultrassom, Raio-X, Citologia, etc.)\n- lab_name: nome do laboratório\n\nAssunto: {{ $('Gmail IMAP - Lab Emails').item.json.subject }}\nDe: {{ $('Gmail IMAP - Lab Emails').item.json.from }}\n\nCorpo do email:\n{{ $('Gmail IMAP - Lab Emails').item.json.text || $('Gmail IMAP - Lab Emails').item.json.html || '' }}\n\nTexto extraído do PDF anexado:\n{{ $('Extract PDF Text').item.json.data || 'Nenhum PDF anexado' }}\n\nRetorne SOMENTE o JSON, exemplo: {\"pet_name\": \"Rex\", \"client_name\": \"Maria Silva\", \"exam_type\": \"Hemograma\", \"lab_name\": \"VetLab SP\"}"
            }
          ]
        },
        "options": {
          "temperature": 0.1
        }
      },
      "id": "d8966efd-3796-4cca-a8af-6f45439ca5a3",
      "name": "OpenAI - Parse Email",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [-640, 96],
      "credentials": {
        "openAiApi": {
          "id": "vKBno59QWhuUp1sz",
          "name": "OpenAi account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Parse JSON response from OpenAI\nconst emailData = $('Gmail IMAP - Lab Emails').item.json;\nconst openaiResponse = $input.item.json.message?.content || '{}';\n\nlet parsed;\ntry {\n  // Limpa possível markdown no response\n  const cleaned = openaiResponse.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  parsed = JSON.parse(cleaned);\n} catch(e) {\n  parsed = { pet_name: null, client_name: null, exam_type: null, lab_name: null };\n}\n\nreturn {\n  // Dados do email original\n  email_message_id: emailData.metadata?.['message-id'] || emailData.messageId || String(emailData.attributes?.uid),\n  email_subject: emailData.subject,\n  email_from: emailData.from,\n  // Dados parseados pelo LLM\n  pet_name_parsed: parsed.pet_name || null,\n  client_name_parsed: parsed.client_name || null,\n  exam_type: parsed.exam_type || null,\n  lab_name: parsed.lab_name || null,\n  // Timestamp\n  email_received_at: new Date().toISOString()\n};"
      },
