      "id": "0ca5cb3e-948a-4b70-aaf5-9bc7fd3b3da6",
      "name": "Supabase - Match Pet by Name",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [384, 192]
    },
    {
      "parameters": {
        "jsCode": "const parsed = $('Code - Extract Parsed Data').item.json;\nconst petData = $('Supabase - Match Pet by Name').item.json;\n\nconst hasPet = Array.isArray(petData) && petData.length > 0;\nconst pet = hasPet ? petData[0] : null;\n\nreturn {\n  email_message_id: parsed.email_message_id,\n  email_subject: parsed.email_subject,\n  email_from: parsed.email_from,\n  email_received_at: parsed.email_received_at,\n  exam_type: parsed.exam_type,\n  lab_name: parsed.lab_name,\n  pet_name_parsed: parsed.pet_name_parsed,\n  client_name_parsed: parsed.client_name_parsed,\n  origin: 'email',\n  // Pet match\n  pet_id: hasPet ? pet.id : null,\n  client_code: hasPet ? pet.client_code : null,\n  // Status: se achou pet → aguardando_contato, senão → recebido com warning\n  status: hasPet ? 'aguardando_contato' : 'recebido',\n  alert_level: hasPet ? 'normal' : 'warning'\n};"
      },
