    {
      "parameters": {
        "jsCode": "// Resolve o ID do tracking (seja update ou insert)\nconst fromUpdate = $('Supabase - Update Sale Tracking').item?.json;\nconst fromInsert = $('Supabase - Insert New Tracking').item?.json;\n\nconst trackingData = fromUpdate?.[0] || fromInsert?.[0];\nconst trackingId = trackingData?.id;\n\nif (!trackingId) throw new Error('No tracking ID found');\n\nreturn {\n  tracking_id: trackingId,\n  was_sale_match: !!fromUpdate?.[0]\n};"
      },
